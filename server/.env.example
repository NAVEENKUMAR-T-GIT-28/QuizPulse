# ─── Server Configuration ──────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────
# MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/quizpulse

# ─── Authentication ──────────────────────────────────────
# Secret key for signing JWT tokens. Use a long, random string.
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ─── Client ──────────────────────────────────────────────
# URL(s) of the frontend application. Supports comma-separated list.
CLIENT_URL=http://localhost:5173,http://your_second_test_url

# ─── Features ────────────────────────────────────────────
# Set to 'true' to enable high-quality PDF exports using Puppeteer.
# Requires a Chromium binary to be available in the environment.
# If 'false' or omitted, simple PDFKit exports will be used instead.
ENABLE_PUPPETEER=false