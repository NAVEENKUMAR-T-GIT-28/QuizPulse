# ─── Server Configuration ────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database ────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Whitelist 0.0.0.0/0 in Atlas Network Access for Render dynamic IPs
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/quizpulse?retryWrites=true&w=majority

# ─── Test Database (REQUIRED if running `npm test`) ──────────────────
# A SEPARATE database used exclusively by the test suite.
# The test helper NEVER falls back to MONGODB_URI — it would wipe production data.
# Create a free cluster on Atlas and add a "quizpulse-test" database, OR
# use a local MongoDB instance (default fallback):
#   TEST_MONGODB_URI=mongodb://127.0.0.1:27017/quizpulse-test
# For Atlas (recommended for CI):
TEST_MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/quizpulse-test?retryWrites=true&w=majority


# ─── Authentication ──────────────────────────────────────────────────
# JWT signing secret — MUST be a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ─── Client ──────────────────────────────────────────────────────────
# Production frontend URL (Vercel domain). Comma-separated for multiple.
# No trailing slash.
CLIENT_URL=https://quizpulse.vercel.app

# ─── PDF Export ──────────────────────────────────────────────────────
# Set to 'true' only on instances with enough RAM (512MB+ dedicated).
# On Render free tier (512MB shared), leave false — PDFKit fallback is used.
ENABLE_PUPPETEER=false

# ─── Email / SMTP (for OTP verification) ─────────────────────────────────────
# Gmail with App Password (recommended):
#   1. Enable 2-Step Verification on your Google account
#   2. Create an App Password at myaccount.google.com/apppasswords
#   3. Fill in SMTP_USER (your Gmail) and SMTP_PASS (the app password)
# For other providers set SMTP_HOST / SMTP_PORT too.
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password
# SMTP_FROM="QuizPulse" <you@gmail.com>   # optional display name
# SMTP_HOST=smtp.gmail.com                # default
# SMTP_PORT=587                           # default
# SMTP_SECURE=false                       # set true for port 465

# ─── Observability ───────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=info