# ─── Server Configuration ────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database ────────────────────────────────────────────────────────
# MongoDB Atlas connection string
# Whitelist 0.0.0.0/0 in Atlas Network Access for Render dynamic IPs
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/quizpulse?retryWrites=true&w=majority

# ─── Authentication ──────────────────────────────────────────────────
# JWT signing secret — MUST be a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ─── Client ──────────────────────────────────────────────────────────
# Production frontend URL (Vercel domain). Comma-separated for multiple.
# No trailing slash.
CLIENT_URL=https://quizpulse.vercel.app

# ─── PDF Export ──────────────────────────────────────────────────────
# Set to 'true' only on instances with enough RAM (512MB+ dedicated).
# On Render free tier (512MB shared), leave false — PDFKit fallback is used.
ENABLE_PUPPETEER=false