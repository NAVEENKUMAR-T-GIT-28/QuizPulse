# ─── Vite Development Server Configuration ───

# The backend server URL for proxying API and WebSocket requests.
# Defaults to http://localhost:5000 if not set.
VITE_SERVER_URL=http://localhost:5000

# Optional: Add a specific host to allowedHosts (e.g., for ngrok tunnels)
# VITE_ALLOWED_HOST=your-ngrok-url.ngrok-free.dev
